    "@types/react-dom": "18.2.18",
    "autoprefixer": "10.4.17",
    "postcss": "8.4.33",
    "tailwindcss": "3.4.1",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "storage",
      "sidePanel",
      "tabs",
      "activeTab"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
