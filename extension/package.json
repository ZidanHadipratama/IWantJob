{
  "name": "iwantjob-extension",
  "displayName": "IWantJob",
  "version": "0.0.1",
  "description": "AI-powered job application assistant",
  "author": "",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "playwright:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:headed": "PLAYWRIGHT_EXTENSION_HEADLESS=0 playwright test"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "lucide-react": "^0.577.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.0.268",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "10.4.17",
    "postcss": "8.4.33",
    "tailwindcss": "3.4.1",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "storage",
      "sidePanel",
      "tabs",
      "activeTab",
      "scripting"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    }
  }
}
